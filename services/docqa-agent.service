# Document Q&A Agent — Port 8006
[Unit]
Description=VCS Document Q&A Agent (Port 8006)
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/vcsai/document-qa-agent
EnvironmentFile=/home/ubuntu/vcsai/document-qa-agent/.env
ExecStart=/home/ubuntu/vcsai/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8006 --workers 1
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=docqa-agent
LimitNOFILE=65536
TimeoutStartSec=30
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
